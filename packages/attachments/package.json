{
  "name": "@m-next/attachments",
  "private": true,
  "version": "1.0.0",
  "description": "Attachments component for handling file attachments",
  "keywords": [
    "attachments",
    "file",
    "upload"
  ],
  "author": "Alexander Ballard <a.ballard@method.me>",
  "homepage": "",
  "license": "ISC",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "directories": {
    "src": "src"
  },
  "files": [
    "index"
  ],
  "dependencies": {
    "@m-next/styles": "1.0.0",
    "@m-next/utilities": "1.0.0",
    "@m-next/svg-icon": "1.0.0",
    "@m-next/checkbox": "1.0.0",
    "@m-next/button": "1.0.0",
    "@m-next/caption": "1.0.0",
    "@m-next/typeography": "1.0.0",
    "date-fns": "^2.30.0",
    "simplebar-react": "3.3.0"

  },
  "peerDependencies": {
    "@emotion/react": ">=11.10.5",
    "@emotion/styled": ">=11.10.5",
    "react": ">=17.0.2",
    "react-dom": ">=17.0.2",
    "prop-types": ">=15.8.1"
  },
  "devDependencies": {
    "@types/react": "^17.0.2",
    "@types/react-dom": "^17.0.2",
    "typescript": "^4.9.5"
  },
  "scripts": {
    "dev": "webpack --mode development",
    "prod": "webpack --mode production",
    "build": "npm run prettify && npm run lint && npm run test && npm run check-types && webpack --mode production",
    "prettify": "npx prettier \"**/*.*(js|jsx|ts|tsx)\" --ignore-path=.prettierignore --write --log-level=error",
    "release": "npm build && npm publish build --tag next",
    "test": "jest --passWithNoTests",
    "test-snapshot-update": "npm run test -- -u",
    "test-storybook": "jest --passWithNoTests --json --outputFile=.jest-test-results.json",
    "lint-js": "npx eslint \"src/**/*.{js,jsx,ts,tsx}\" --cache --report-unused-disable-directives --max-warnings=0",
    "lint": "npm run lint-js",
    "lint-fix": "npx eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix --cache --report-unused-disable-directives --max-warnings=0",
    "check-types": "tsc --noemit"
  }
}