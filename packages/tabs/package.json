  "main": "src/index.js",
  "types": "src/Tabs.d.ts",
  "directories": {
    "src": "src"
  },
  "files": [
    "index",
    "Tabs.d.ts"
  ],
  "dependencies": {
    "@m-next/styles": "1.0.0",
    "@m-next/svg-icon": "1.0.0",
    "@m-next/utilities": "1.0.0",
    "react-tooltip": "^5.26.3",
    "react-resize-detector": "^9.1.0",
    "react-beautiful-dnd": "^13.1.1"
  },
  "peerDependencies": {
    "@emotion/react": ">=11.10.5",
    "@emotion/styled": ">=11.10.5",
