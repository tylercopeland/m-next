  "dependencies": {
    "@mui/material": "^5.15.20",
    "@m-next/styles": "1.0.0",
    "@m-next/container": "1.0.0",
    "@m-next/utilities": "1.0.0",
    "@m-next/types": "1.0.0",
    "@m-next/typeography": "1.0.0",
    "@m-next/input": "1.0.0",
    "@m-next/button": "1.0.0",
    "@m-next/svg-icon": "1.0.0",
    "@m-next/datepicker": "1.0.0",
    "@m-next/popover": "1.0.0",
    "@m-next/dropdown": "1.0.0",
    "@m-next/pill": "1.0.0",
    "@m-next/menu": "1.0.0",
    "@m-next/radio-button": "1.0.0",
    "@m-next/loading-skeleton": "1.0.0",
