  top: 50%;
  -webkit-transform: translate(-50%, -50%);
  -moz-transform: translate(-50%, -50%);
  -ms-transform: translate(-50%, -50%);
  transform: translate(-50%, -50%);
  width: 4px;
  height: 4px;
  background-color: #FFFFFF!important;
  border-radius: 100%;
}

.emotion-100:hover input~div .radio-btn-indicator {
  box-shadow: 0 0 0 1px #0D71C8;
}

.emotion-100 input:focus~div .radio-btn-indicator {
  box-shadow: 0 0 0 1px #0D71C8;
  border-color: #E5F7FF;
}

@media screen and (-ms-high-contrast: active) {
  .emotion-100 input:checked~div .radio-btn-indicator {
    background-color: #FFFFFF;
    border-color: #FFFFFF;
    box-shadow: 0 0 0 #FFFFFF;
  }

  .emotion-100 input:focus~div .radio-btn-indicator {
    box-shadow: 0 0 0 1px #FFFFFF;
    border-color: #FFFFFF;
  }
}

