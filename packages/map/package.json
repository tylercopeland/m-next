{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@m-next/map",
  "private": true,
  "version": "1.0.0",
  "description": "Map widget with Mapbox integration",
  "keywords": [
    "map",
    "mapbox",
    "geography",
    "visualization"
  ],
  "author": "Method Development Team",
  "homepage": "",
  "license": "ISC",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "directories": {
    "src": "src"
  },
  "files": [
    "index",
    "index.d.ts"
  ],
  "dependencies": {
    "@m-next/styles": "1.0.0",
    "@m-next/svg-icon": "1.0.0",
    "@m-next/utilities": "1.0.0",
    "@turf/turf": "^5.1.6",
    "axios": "^1.6.0",
    "mapbox-gl": "^1.13.0",
    "react-map-gl": "^5.3.21",
    "viewport-mercator-project": "^7.0.4"
  },
  "peerDependencies": {
    "@emotion/react": ">=11.10.5",
    "@emotion/styled": ">=11.10.5",
    "prop-types": ">=15.8.1",
    "react": ">=17.0.2",
    "react-dom": ">=17.0.2"
  },
  "scripts": {
    "dev": "webpack --mode development",
    "prod": "webpack --mode production",
    "build": "npm run prettify && npm run lint && npm run test &&  webpack --mode production",
    "prettify": "npx prettier \"**/*.*(js|jsx)\" --ignore-path=.prettierignore --write --log-level=error",
    "release": "npm build && npm publish build --tag next",
    "test": "jest  --passWithNoTests",
    "test-snapshot-update": "npm run test -- -u",
    "test-storybook": "jest --passWithNoTests --json --outputFile=.jest-test-results.json",
    "lint-js": "npx eslint \"src/**/*.{js,jsx,ts,tsx}\" --cache --report-unused-disable-directives --max-warnings=0",
    "lint-ls": "npx ls-lint",
    "lint": "npm run lint-js && npm run lint-ls",
    "lint-fix": "npx eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix --cache --report-unused-disable-directives --max-warnings=0"
  }
}
