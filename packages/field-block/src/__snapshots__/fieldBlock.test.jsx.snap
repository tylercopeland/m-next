exports[`Field Block Snapshots show error 1`] = `
.emotion-0 {
  display: -webkit-box;
  display: -webkit-flex;
  display: -ms-flexbox;
  display: flex;
  box-sizing: border-box;
  padding: 8px;
  background-color: #FFFFFF;
  -webkit-flex-direction: column;
  -ms-flex-direction: column;
  flex-direction: column;
  width: 100%;
  height: unset;
  cursor: default;
}

.emotion-2 {
  display: -webkit-box;
  display: -webkit-flex;
  display: -ms-flexbox;
  display: flex;
  width: 100%;
  -webkit-flex-direction: column;
  -ms-flex-direction: column;
  flex-direction: column;
  -webkit-align-items: center;
  -webkit-box-align: center;
  -ms-flex-align: center;
  align-items: center;
  gap: 8px;
}

.emotion-4 {
  background-color: rgba(0, 0, 0, 0);
  color: #0D71C8;
  min-height: 32px;
  padding: 6px 16px;
  -webkit-align-items: center;
  -webkit-box-align: center;
  -ms-flex-align: center;
  align-items: center;
  border-radius: 17px!important;
  box-sizing: border-box;
  font-size: 14px;
  font-weight: 600;
  width: auto;
  line-height: 18px;
  border: none;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.emotion-4:hover {
  border: none;
  color: #064499;
  cursor: pointer;
}

.emotion-4:active {
  background-color: #E5F7FF;
  color: #000000;
}

.emotion-4:focus {
  border: none;
  color: #064499;
}

.emotion-4:disabled {
  opacity: 0.5;
}

.emotion-4:focus-visible {
  outline: none;
  box-shadow: 0 0 0.75pt 1.5pt #0D71C8;
  border-color: #FFFFFF!important;
}

<div>
  <div
    class="emotion-0 emotion-1"
    height="unset"
    id="-field-block-container"
    width="100%"
  >
    <div
      class="emotion-2 emotion-3"
    >
      <strong>
        Unable to load fields
      </strong>
      <button
        class="emotion-4 emotion-5"
        data-testid="-field-block-refetch"
        id="-field-block-refetch"
        tabindex="0"
        type="button"
      >
        Try again
      </button>
    </div>
  </div>
</div>
`;
