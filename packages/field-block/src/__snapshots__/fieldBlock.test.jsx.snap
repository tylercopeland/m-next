  text-align: center;
  vertical-align: middle;
  color: hsl(0, 0%, 80%);
  padding: 8px;
  box-sizing: border-box;
}

.emotion-290 {
  -webkit-animation: animation-0 1s ease-in-out 0ms infinite;
  animation: animation-0 1s ease-in-out 0ms infinite;
  background-color: currentColor;
  border-radius: 1em;
  display: inline-block;
  height: 1em;
  vertical-align: top;
  width: 1em;
}

.emotion-291 {
  -webkit-animation: animation-0 1s ease-in-out 160ms infinite;
  animation: animation-0 1s ease-in-out 160ms infinite;
  background-color: currentColor;
  border-radius: 1em;
  display: inline-block;
  margin-left: 1em;
  height: 1em;
  vertical-align: top;
  width: 1em;
}

.emotion-292 {
  -webkit-animation: animation-0 1s ease-in-out 320ms infinite;
  animation: animation-0 1s ease-in-out 320ms infinite;
  background-color: currentColor;
  border-radius: 1em;
  display: inline-block;
  margin-left: 1em;
  height: 1em;
  vertical-align: top;
  width: 1em;
}

.emotion-301 {
  position: relative;
  display: inline-block;
  border: none;
  width: 32px;
  height: auto;
  min-width: 0;
  opacity: 1;
  pointer-events: auto;
}

.emotion-301 focus {
  outline: none;
}

.emotion-303 {
  display: inline-block;
  border-radius: 3px;
  width: 100%;
  height: auto;
  overflow: hidden;
}

body.user-is-tabbing .emotion-303:focus {
  --outline-offset-box-shadow-color: white;
  --outline-box-shadow-color: #0D71C8;
  box-shadow: 0 0 0 2pt var(--outline-offset-box-shadow-color),0 0 0.75pt 3.5pt var(--outline-box-shadow-color);
  overflow: visible;
}

.emotion-305 {
  width: auto;
  height: auto;
  max-width: 100%;
  max-height: 100%;
  outline: none;
  cursor: pointer;
}

.emotion-320 {
  grid-area: 1/1/2/3;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #2A394AFF;
  margin-left: 2px;
  margin-right: 2px;
  box-sizing: border-box;
}

.emotion-321 {
  display: -webkit-box;
  display: -webkit-flex;
  display: -ms-flexbox;
  display: flex;
  -webkit-align-content: center;
  -ms-flex-line-pack: center;
  align-content: center;
  -webkit-flex-direction: column;
  -ms-flex-direction: column;
  flex-direction: column;
}

.emotion-323 {
  display: -webkit-box;
  display: -webkit-flex;
  display: -ms-flexbox;
  display: flex;
  gap: 8px;
  -webkit-align-content: center;
  -ms-flex-line-pack: center;
  align-content: center;
  -webkit-align-items: center;
  -webkit-box-align: center;
  -ms-flex-align: center;
  align-items: center;
  font-weight: 600;
  -webkit-flex: 1;
  -ms-flex: 1;
  flex: 1;
}

.emotion-333 {
  display: -webkit-box;
  display: -webkit-flex;
  display: -ms-flexbox;
  display: flex;
  -webkit-box-pack: end;
  -ms-flex-pack: end;
  -webkit-justify-content: flex-end;
  justify-content: flex-end;
  gap: 8px;
  -webkit-flex-direction: row;
  -ms-flex-direction: row;
  flex-direction: row;
}

