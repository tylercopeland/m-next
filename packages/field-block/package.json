  },
  "files": [
    "index"
  ],
  "dependencies": {
    "@m-next/styles": "1.0.0",
    "@m-next/types": "1.0.0",
    "@m-next/input": "1.0.0",
    "@m-next/container": "1.0.0",
    "@m-next/button": "1.0.0",
    "@m-next/utilities": "1.0.0",
    "@m-next/pill": "1.0.0",
    "@m-next/loading-skeleton": "1.0.0",
    "@m-next/address": "1.0.0",
    "@m-next/tag-widget": "1.0.0",
    "@m-next/image": "1.0.0",
    "@m-next/dropdown": "^1.0.0",
    "@m-next/datepicker": "^1.0.0",
    "@m-next/checkbox": "^1.0.0",
    "@m-next/svg-icon": "^1.0.0"


  },
  "peerDependencies": {
    "@emotion/react": ">=11.10.5",
