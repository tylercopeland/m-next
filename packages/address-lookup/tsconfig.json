{
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "**/*.test.*",
    "**/*.spec.*",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/*.stories.*",
    "**/*.story.*",
    "dist"
  ],
  "compilerOptions": {
    "allowJs": true,
    "declaration": true,
    "outDir": "dist/assets/js",
    "declarationMap": true,
    "jsx": "react-jsx",
    "target": "es5",
    "lib": ["dom", "es6"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmitOnError": false
  }
}