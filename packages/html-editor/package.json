{
  "name": "@m-next/html-editor",
  "private": true,
  "version": "1.0.0",
  "description": "Html editor for M-One",
  "main": "src/index.ts",
  "directories": {
    "src": "src"
  },
  "files": [
    "index"
  ],
  "scripts": {
    "dev": "webpack --mode development",
    "prod": "webpack --mode production",
    "build": "npm run lint && npm test && npm run check-types && webpack --mode production",
    "prettify": "npx prettier \"**/*.*(js|jsx|ts|tsx)\" --ignore-path=.prettierignore --write --log-level=error",
    "release": "npm build && npm publish build --tag next",
    "test": "jest",
    "test-snapshot-update": "npm run test -- -u",
    "test-storybook": "jest --json --outputFile=.jest-test-results.json",
    "lint-js": "npx eslint \"src/**/*.{js,jsx,ts,tsx}\" --cache --report-unused-disable-directives --max-warnings=0",
    "lint-ls": "npx ls-lint",
    "lint": "npm run lint-js && npm run lint-ls",
    "lint-fix": "npx eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix --cache --report-unused-disable-directives --max-warnings=0",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=17.0.2",
    "react-dom": ">=17.0.2"
  },
  "dependencies": {
    "@emotion/styled": "^11.14.0",
    "@m-next/map": "^1.0.0",
    "@m-next/styles": "^1.0.0",
    "@m-next/svg-icon": "^1.0.0",
    "@m-next/validation": "^1.0.0",
    "froala-editor": "4.0.14",
    "react-froala-wysiwyg": "4.0.14",
    "react-select": "^5.10.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.15",
    "@babel/preset-typescript": "^7.23.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3",
    "typescript": "^5.2.2",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  }
}
