{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2021", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "types": ["jest"],                   // ✅ Let Jest provide global types
    "isolatedModules": true             // ✅ Required for ts-jest in ESM mode
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}