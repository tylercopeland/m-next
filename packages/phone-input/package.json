{
  "name": "@m-next/phone-input",
  "private": true,
  "version": "1.0.0",
  "description": "Phone input with international code selector",
  "keywords": [
    "input",
    "phone"
  ],
  "author": "Alejandro Mejia Morales <a.morales@method.me>",
  "homepage": "",
  "license": "ISC",
  "main": "src/index.ts",
  "types": "src/index.d.ts",
  "directories": {
    "src": "src"
  },
  "files": [
    "src",
    "index.d.ts"
  ],
  "peerDependencies": {
    "@emotion/react": ">=11.10.4",
    "@emotion/styled": ">=11.10.4",
    "prop-types": ">=15.8.1",
    "react": ">=17.0.2",
    "react-dom": ">=17.0.2"
  },
  "dependencies": {
    "@m-next/caption": "^1.0.0",
    "@m-next/styles": "^1.0.0",
    "@m-next/svg-icon": "^1.0.0",
    "@m-next/tokens": "^1.0.0",
    "react-phone-input-2": "^2.15.1"
  },
  "devDependencies": {
    "ts-jest": "^29.1.1"
  },
  "scripts": {
    "dev": "webpack --mode development",
    "prod": "webpack --mode production",
    "build": "npm run lint && npm test && webpack --mode production",
    "prettify": "npx prettier \"**/*.*(js|jsx)\" --ignore-path=.prettierignore --write --log-level=error",
    "release": "npm build && npm publish build --tag next",
    "test": "jest",
    "test-storybook": "jest --json --outputFile=.jest-test-results.json",
    "lint-js": "npx eslint \"src/**/*.{js,jsx,ts,tsx}\" --cache --report-unused-disable-directives --max-warnings=0",
    "lint-ls": "npx ls-lint",
    "lint": "npm run lint-js && npm run lint-ls",
    "lint-fix": "npx eslint \"src/**/*.{js,jsx,ts,tsx}\" --fix --cache --report-unused-disable-directives --max-warnings=0",
    "check-types": "tsc --noemit",
    "test-snapshot-update": "npm run test -- -u"

  }
}
