{
  "features": {
    "app-builder": {
      "description": "WYSIWYG screen designer",
      "playwright": ["tests/app-builder/"],
      "m-one": ["@m-next/app-builder-core", "@m-next/layout-canvas"],
      "patterns": ["--testPathPattern=\"control-classes\"", "--testPathPattern=\"editors\"", "--testPathPattern=\"screenLayoutSlice\""]
    },
    "account-settings": {
      "description": "User management and account configuration",
      "playwright": ["tests/common/accont-settings/"],
      "m-one": [],
      "patterns": []
    },
    "accounts": {
      "description": "Accounts app (CRM)",
      "playwright": ["tests/accounts/"],
      "m-one": ["@m-next/grid", "@m-next/input", "@m-next/dropdown"],
      "patterns": []
    },
    "activities": {
      "description": "Activity management and scheduling",
      "playwright": ["tests/activities/"],
      "m-one": ["@m-next/calendar", "@m-next/datepicker", "@m-next/grid"],
      "patterns": []
    },
    "work-orders": {
      "description": "Work order management",
      "playwright": ["tests/001-work-orders/"],
      "m-one": ["@m-next/calendar", "@m-next/datepicker", "@m-next/grid"],
      "patterns": []
    },
    "grids": {
      "description": "Data grids and editable grids",
      "playwright": ["tests/app-builder/"],
      "m-one": ["@m-next/grid"],
      "patterns": ["--testPathPattern=\"gridControl\"", "--testPathPattern=\"grid-block-editor\""],
      "grep": ["-g \"Editable Grids\"", "-g \"Grids\""]
    },
    "invoices": {
      "description": "Invoice management",
      "playwright": ["tests/006-invoices/"],
      "m-one": ["@m-next/grid"],
      "patterns": []
