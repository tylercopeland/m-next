    "purchase-orders": {
      "description": "Purchase order management",
      "playwright": ["tests/003-purchase-orders/"],
      "m-one": ["@m-next/grid"],
      "patterns": []
    },
    "sales-orders": {
      "description": "Sales order management",
      "playwright": ["tests/005-sales-order/"],
      "m-one": ["@m-next/grid"],
      "patterns": []
    },
    "portal": {
      "description": "Customer portal",
      "playwright": ["tests/007-portal/"],
      "m-one": [],
      "patterns": []
    },
    "dashboard": {
      "description": "Dashboard and insights",
      "playwright": ["tests/dashboard/"],
      "m-one": ["@m-next/chart", "@m-next/insight-card"],
      "patterns": []
    }
  },
  "critical-packages": {
    "runtime-interface": {
      "warning": "CRITICAL - Core translation layer",
      "sequence": [
        "npx nx test @m-next/runtime-interface",
        "npm run affected-test",
        "npx playwright test tests/app-builder/"
      ]
    },
    "types": {
      "warning": "CRITICAL - Widget type definitions",
      "sequence": [
        "npx nx test @m-next/types",
        "npm run affected-test"
      ]
    }
  }
}
